<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Life Tycoon v1.7 - Full Restore</title>
    <style>
        :root {
            --bg-color: #0d1117; --card-bg: #161b22; --border: #30363d;
            --gold: #f1c40f; --red: #e74c3c; --blue: #3498db; --green: #2ecc71;
            --purple: #9b59b6; --orange: #e67e22; --text: #c9d1d9;
        }

        body {
            font-family: 'Segoe UI', sans-serif; background-color: var(--bg-color);
            color: var(--text); margin: 0; padding: 10px; display: flex; flex-direction: column; align-items: center;
        }

        .game-container { width: 100%; max-width: 500px; padding-bottom: 90px; }

        /* HUD */
        .hud {
            background: var(--card-bg); padding: 20px 15px; border-radius: 12px; border: 2px solid var(--border);
            margin-bottom: 15px; position: sticky; top: 10px; z-index: 100; text-align: center;
        }
        .oro-display { font-size: 1.8rem; font-weight: bold; color: var(--gold); }
        .oro-label { font-size: 0.7rem; color: #888; text-transform: uppercase; }

        /* SECCIONES */
        .game-section { display: none; }
        .active-section { display: block; }
        .card { background: var(--card-bg); padding: 15px; border-radius: 8px; border: 1px solid var(--border); margin-bottom: 15px; }
        h2 { color: var(--gold); font-size: 0.9rem; margin: 0 0 10px 0; text-transform: uppercase; border-bottom: 1px solid #333; padding-bottom: 5px;}

        input {
            width: 100%; padding: 10px; margin: 5px 0; background: #000;
            border: 1px solid var(--border); color: var(--green); border-radius: 4px; box-sizing: border-box;
        }

        .btn {
            width: 100%; padding: 10px; border: none; border-radius: 4px; 
            font-weight: bold; cursor: pointer; margin-top: 5px; text-transform: uppercase; font-size: 0.65rem;
        }
        .btn-green { background: #238636; color: white; }
        .btn-red { background: var(--red); color: white; }
        .btn-blue { background: var(--blue); color: white; }
        .btn-purple { background: var(--purple); color: white; }

        /* VISUALES */
        .visual-content { width: 50px; height: 50px; object-fit: cover; border-radius: 5px; background: #222; font-size: 1.5rem; display: flex; align-items: center; justify-content: center; margin: 0 auto; }
        .grid-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .item-box { background: #000; border: 1px solid var(--border); padding: 10px; text-align: center; border-radius: 8px; position: relative; }

        /* DEUDAS */
        .cuotas-badge { font-size: 1.2rem; font-weight: bold; color: var(--text); display: block; margin: 5px 0; }
        .progress-bar { background: #000; height: 8px; border-radius: 4px; border: 1px solid #333; overflow: hidden; margin-top: 5px; }
        .progress-fill { height: 100%; background: var(--green); transition: width 0.3s ease; }

        /* HISTORIAL */
        #lista-historial { display: none; margin-top: 10px; max-height: 200px; overflow-y: auto; border-left: 2px solid var(--red); padding-left: 10px; }
        .mov-item { display: flex; justify-content: space-between; font-size: 0.7rem; padding: 4px 0; border-bottom: 1px solid #222; }

        .nav {
            position: fixed; bottom: 0; left: 0; width: 100%; background: #161b22;
            border-top: 2px solid var(--border); display: flex; justify-content: space-around; padding: 10px 0;
        }
        .nav-btn { background: none; border: none; color: #8b949e; cursor: pointer; text-align: center; font-size: 0.6rem;}
        .nav-btn.active { color: var(--gold); }
    </style>
</head>
<body>

    <div class="game-container">
        <div class="hud">
            <div class="oro-label">Oro Disponible</div>
            <div class="oro-display" id="txt-oro">$0</div>
        </div>

        <!-- BILLETERA / DEUDAS -->
        <div id="sec-datos" class="game-section active-section">
            <div class="card">
                <h2>Billetera</h2>
                <input type="number" id="num-mov" placeholder="Monto $">
                <input type="text" id="nom-mov" placeholder="Motivo (Ej: 🍕 Almuerzo)">
                <div style="display:flex; gap:10px;">
                    <button class="btn btn-green" onclick="modOro(1)">SUMAR</button>
                    <button class="btn btn-red" onclick="modOro(-1)">GASTAR</button>
                </div>
                <div onclick="toggleHistorial()" style="cursor:pointer; font-size:0.7rem; margin-top:10px; text-align:center; color:#aaa;">📜 Historial / Gastos Totales 🔽</div>
                <div id="lista-historial"></div>
            </div>

            <div id="cont-deudas"></div>
            
            <div class="card">
                <p style="font-size:0.7rem; color:var(--red);">+ REGISTRAR DEUDA</p>
                <input type="text" id="d-nom" placeholder="¿Qué compraste?">
                <input type="number" id="d-tot" placeholder="Monto total">
                <input type="number" id="d-cuo" placeholder="Número de cuotas">
                <button class="btn btn-red" onclick="crearDeuda()">AÑADIR DEUDA</button>
            </div>
        </div>

        <!-- SERVICIOS -->
        <div id="sec-servicios" class="game-section">
            <div class="card">
                <h2>Servicios</h2>
                <div id="cont-servicios"></div>
                <button class="btn" style="background:#444;" onclick="reiniciarMes()">🔄 REINICIAR MES</button>
            </div>
            <div class="card">
                <input type="text" id="s-nom" placeholder="Nombre (Ej: Netflix)">
                <input type="text" id="s-ico" placeholder="Emoji">
                <input type="number" id="s-pre" placeholder="Costo">
                <button class="btn btn-blue" onclick="crearServicio()">GUARDAR</button>
            </div>
        </div>

        <!-- TIENDA -->
        <div id="sec-tienda" class="game-section">
            <div class="card">
                <h2>Tienda de Deseos</h2>
                <div id="cont-tienda" class="grid-layout"></div>
            </div>
            <div class="card">
                <p style="font-size:0.7rem; color:var(--blue);">+ AÑADIR ARTÍCULO A TIENDA</p>
                <input type="text" id="t-nom" placeholder="¿Qué quieres?">
                <input type="text" id="t-ico" placeholder="Emoji o Link">
                <input type="number" id="t-pre" placeholder="Precio">
                <button class="btn btn-blue" onclick="crearTienda()">AÑADIR</button>
            </div>
        </div>

        <!-- CASA / INVENTARIO (RESTAURADO FORMULARIO MANUAL) -->
        <div id="sec-casa" class="game-section">
            <div class="card">
                <h2>Mi Inventario</h2>
                <div id="cont-inv" class="grid-layout"></div>
            </div>
            <div class="card">
                <p style="font-size:0.7rem; color:var(--green);">+ AÑADIR OBJETO MANUALMENTE</p>
                <input type="text" id="i-nom" placeholder="Nombre del objeto">
                <input type="text" id="i-ico" placeholder="Emoji o Link de Imagen">
                <button class="btn btn-green" onclick="crearInvManual()">AÑADIR A CASA</button>
            </div>
        </div>
    </div>

    <nav class="nav">
        <button class="nav-btn active" onclick="irA('datos', this)"><span>💸</span>DEUDAS</button>
        <button class="nav-btn" onclick="irA('servicios', this)"><span>📋</span>SERVICIOS</button>
        <button class="nav-btn" onclick="irA('tienda', this)"><span>🛒</span>TIENDA</button>
        <button class="nav-btn" onclick="irA('casa', this)"><span>🏠</span>CASA</button>
    </nav>

    <script>
        let db = JSON.parse(localStorage.getItem('lifeTycoonV17')) || {
            oro: 0, deudas: [], servicios: [], tienda: [], casa: [], historial: []
        };

        function guardar() { localStorage.setItem('lifeTycoonV17', JSON.stringify(db)); render(); }

        function modOro(signo) {
            const m = parseFloat(document.getElementById('num-mov').value);
            const n = document.getElementById('nom-mov').value || 'Movimiento';
            if(!isNaN(m)) {
                db.oro += (m * signo);
                if(signo < 0) db.historial.unshift({ n, m: m });
                document.getElementById('num-mov').value = ""; document.getElementById('nom-mov').value = "";
                guardar();
            }
        }

        function pagarCuota(idx, esFantasma) {
            let d = db.deudas[idx];
            if (d.cP < d.cT) {
                if (!esFantasma) {
                    if (db.oro >= d.mC) {
                        db.oro -= d.mC;
                        db.historial.unshift({ n: "Cuota: " + d.n, m: d.mC });
                    } else { alert("Oro insuficiente"); return; }
                }
                d.cP++; d.pagado += d.mC; guardar();
            }
        }

        function crearDeuda() {
            const n = document.getElementById('d-nom').value, t = parseFloat(document.getElementById('d-tot').value), c = parseInt(document.getElementById('d-cuo').value);
            if(n && t && c) { db.deudas.push({ n, t, cT: c, cP: 0, pagado: 0, mC: t/c }); guardar(); }
        }

        function crearServicio() {
            const n = document.getElementById('s-nom').value, i = document.getElementById('s-ico').value || '📄', p = parseFloat(document.getElementById('s-pre').value);
            if(n && p) { db.servicios.push({ nombre: n, icono: i, precio: p, pagado: false }); guardar(); }
        }

        function reiniciarMes() { db.servicios.forEach(s => s.pagado = false); guardar(); }

        function crearTienda() {
            const n = document.getElementById('t-nom').value, i = document.getElementById('t-ico').value || '🎁', p = parseFloat(document.getElementById('t-pre').value);
            if(n && p) { db.tienda.push({ n, i, p }); guardar(); }
        }

        function comprar(idx) {
            const it = db.tienda[idx];
            if(db.oro >= it.p) {
                db.oro -= it.p;
                db.casa.push({ n: it.n, i: it.i });
                db.historial.unshift({ n: "🛒 " + it.n, m: it.p });
                guardar();
            } else { alert("Oro insuficiente"); }
        }

        function crearInvManual() {
            const n = document.getElementById('i-nom').value, i = document.getElementById('i-ico').value || '📦';
            if(n) { db.casa.push({ n, i }); guardar(); }
        }

        function visual(img) {
            if (img && img.startsWith('http')) return `<img src="${img}" class="visual-content">`;
            return `<div class="visual-content">${img}</div>`;
        }

        function render() {
            document.getElementById('txt-oro').textContent = "$" + Math.round(db.oro).toLocaleString();
            
            // Render Deudas
            document.getElementById('cont-deudas').innerHTML = db.deudas.map((d, idx) => `
                <div class="card">
                    <button style="float:right; background:none; border:none; color:red;" onclick="db.deudas.splice(${idx},1);guardar()">×</button>
                    <div style="font-weight:bold; font-size:0.8rem; color:var(--gold)">${d.n.toUpperCase()}</div>
                    <div class="cuotas-badge">${d.cP} / ${d.cT}</div>
                    <div style="display:flex; gap:5px;">
                        <button class="btn btn-blue" onclick="pagarCuota(${idx}, false)">PAGAR $${Math.round(d.mC)}</button>
                        <button class="btn btn-purple" onclick="pagarCuota(${idx}, true)">FANTASMA</button>
                    </div>
                    <div class="progress-bar"><div class="progress-fill" style="width:${(d.cP/d.cT)*100}%"></div></div>
                </div>`).join("");

            // Render Servicios
            document.getElementById('cont-servicios').innerHTML = db.servicios.map((s, idx) => `
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:5px; background:#000; padding:8px; border-radius:5px;">
                    <span style="font-size:0.8rem;">${s.icono} ${s.nombre}</span>
                    <button class="btn" style="width:70px; margin:0; background:${s.pagado?'var(--green)':'var(--blue)'}" 
                    onclick="if(!db.servicios[${idx}].pagado && db.oro >= ${s.precio}){db.oro-=${s.precio}; db.servicios[${idx}].pagado=true; db.historial.unshift({n:'${s.nombre}', m:${s.precio}}); guardar()}">
                    ${s.pagado?'OK':'$'+s.precio}</button>
                </div>`).join("");

            // Render Tienda
            document.getElementById('cont-tienda').innerHTML = db.tienda.map((it, idx) => `
                <div class="item-box">
                    <button style="position:absolute; top:2px; right:5px; color:red; background:none; border:none;" onclick="db.tienda.splice(${idx},1);guardar()">×</button>
                    ${visual(it.i)}
                    <div style="font-size:0.7rem; margin:5px 0;">${it.n}</div>
                    <button class="btn btn-blue" onclick="comprar(${idx})">$${it.p.toLocaleString()}</button>
                </div>`).join("");

            // Render Casa
            document.getElementById('cont-inv').innerHTML = db.casa.map((it, idx) => `
                <div class="item-box">
                    <button style="position:absolute; top:2px; right:5px; color:red; background:none; border:none;" onclick="db.casa.splice(${idx},1);guardar()">×</button>
                    ${visual(it.i)}
                    <div style="font-size:0.65rem; margin-top:5px;">${it.n}</div>
                </div>`).join("");

            // Render Historial
            const totalG = db.historial.reduce((a, b) => a + b.m, 0);
            document.getElementById('lista-historial').innerHTML = `<div style="color:var(--red); font-weight:bold; padding:5px; border:1px solid var(--red); margin-bottom:10px; text-align:center;">TOTAL GASTADO: $${Math.round(totalG).toLocaleString()}</div>` + 
                db.historial.map(h => `<div class="mov-item"><span>${h.n}</span><span style="color:red">-$${h.m.toLocaleString()}</span></div>`).join("");
        }

        function irA(s, b) {
            document.querySelectorAll('.game-section').forEach(x => x.classList.remove('active-section'));
            document.getElementById('sec-' + s).classList.add('active-section');
            document.querySelectorAll('.nav-btn').forEach(x => x.classList.remove('active'));
            b.classList.add('active');
        }
        function toggleHistorial() { const l = document.getElementById('lista-historial'); l.style.display = l.style.display === 'block' ? 'none' : 'block'; }
        
        render();
    </script>
</body>
</html>
